# ============================================================
# EVO Labs Research — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================


# ─────────────────────────────────────────────────────────────
# Supabase
# Dashboard → Settings → API
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key                     # "anon public" key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key                 # server-only, never expose to browser


# ─────────────────────────────────────────────────────────────
# NextAuth.js
# NEXTAUTH_SECRET: run `openssl rand -base64 32` to generate
# NEXTAUTH_URL: your full domain (no trailing slash)
# ─────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-random-32-char-secret
NEXTAUTH_URL=https://evolabsresearch.co


# ─────────────────────────────────────────────────────────────
# Email — SMTP (Magic Link auth via NextAuth + transactional mail)
# Resend SMTP: host=smtp.resend.com, port=465, user=resend
# resend.com → API Keys → Create key (use as EMAIL_SERVER_PASSWORD)
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key                           # direct Resend API (if used)
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=re_your-resend-api-key                    # same as RESEND_API_KEY
EMAIL_FROM=EVO Labs Research <noreply@evolabsresearch.co>


# ─────────────────────────────────────────────────────────────
# Twilio (Phone SMS OTP via Twilio Verify)
# console.twilio.com → Account → Manage → Keys
# Verify service: console.twilio.com → Verify → Services
# ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx    # from Twilio Verify Services


# ─────────────────────────────────────────────────────────────
# Admin Panel
# ADMIN_SECRET: Authorization: Bearer token for /api/admin/* routes
# NEXT_PUBLIC_ADMIN_EMAIL / _PW: shown on the admin login page (client-visible)
# ─────────────────────────────────────────────────────────────
ADMIN_SECRET=your-admin-api-secret-token
NEXT_PUBLIC_ADMIN_EMAIL=evolabs13@gmail.com
NEXT_PUBLIC_ADMIN_PW=your-admin-panel-password


# ─────────────────────────────────────────────────────────────
# Hummingbird Payments (primary checkout processor)
# hummingbird.paywithwallet.net → Dashboard → API Keys
# ─────────────────────────────────────────────────────────────
HUMMINGBIRD_SERVER_URL=https://hummingbird.paywithwallet.net
HUMMINGBIRD_PUBLIC_KEY=your-hummingbird-public-key
HUMMINGBIRD_SECRET_KEY=your-hummingbird-secret-key


# ─────────────────────────────────────────────────────────────
# Stripe (optional — fallback payment method)
# dashboard.stripe.com → Developers → API Keys
# Set NEXT_PUBLIC_STRIPE_ENABLED=true to show Stripe at checkout
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_ENABLED=false
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key
STRIPE_SECRET_KEY=sk_live_your-secret-key


# ─────────────────────────────────────────────────────────────
# Link.money (ACH bank payments — optional)
# ─────────────────────────────────────────────────────────────
LINKMONEY_CLIENT_ID=your-linkmoney-client-id
LINKMONEY_CLIENT_SECRET=your-linkmoney-client-secret
LINKMONEY_API_BASE_URL=https://api.link.money                   # default, override for staging
LINKMONEY_REDIRECT_URL=https://evolabsresearch.co/checkout      # override if needed


# ─────────────────────────────────────────────────────────────
# EasyPost (shipping labels & rate shopping)
# easypost.com → API Keys
# Use TEST key locally; swap to PRODUCTION key on Vercel
# ─────────────────────────────────────────────────────────────
SHIPPO_API_KEY=          # From goshippo.com → API → Test Token
SHIPPO_TEST_MODE=true    # Set to false in production

# Ship-from address (Tampa warehouse)
SHIP_FROM_NAME=EVO Labs Research
SHIP_FROM_COMPANY=EVO Labs Research LLC
SHIP_FROM_STREET=8270 Woodland Center Blvd
SHIP_FROM_CITY=Tampa
SHIP_FROM_STATE=FL
SHIP_FROM_ZIP=33614
SHIP_FROM_COUNTRY=US
SHIP_FROM_PHONE=8328711699


# ─────────────────────────────────────────────────────────────
# AfterShip (shipment tracking)
# app.aftership.com → Settings → API Keys
# ─────────────────────────────────────────────────────────────
AFTERSHIP_API_KEY=your-aftership-api-key


# ─────────────────────────────────────────────────────────────
# Omnisend (email + SMS marketing automation)
# app.omnisend.com → Store Settings → API Keys
# NEXT_PUBLIC_OMNISEND_BRAND_ID: shown in <script> tag (safe to expose)
# ─────────────────────────────────────────────────────────────
OMNISEND_API_KEY=your-omnisend-api-key
NEXT_PUBLIC_OMNISEND_BRAND_ID=your-omnisend-brand-id            # from Omnisend embed snippet


# ─────────────────────────────────────────────────────────────
# WooCommerce REST API (product sync from evolabsresearch.com)
# evolabsresearch.com WP admin → WooCommerce → Settings → Advanced → REST API
# Create a key with Read/Write permissions
# ─────────────────────────────────────────────────────────────
WC_STORE_URL=https://evolabsresearch.com                        # old WP server (not .co)
WC_CONSUMER_KEY=ck_your_consumer_key
WC_CONSUMER_SECRET=cs_your_consumer_secret

# WooCommerce Webhook Secret
# evolabsresearch.com → WooCommerce → Settings → Advanced → Webhooks
# Set webhook URL to: https://evolabsresearch.co/api/webhooks/woocommerce
WC_WEBHOOK_SECRET=your-woocommerce-webhook-secret


# ─────────────────────────────────────────────────────────────
# Anthropic Claude (AI chat widget — /api/chat)
# console.anthropic.com → API Keys
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key


# ─────────────────────────────────────────────────────────────
# Google Analytics 4 (optional)
# analytics.google.com → Admin → Data Streams → Measurement ID
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX


# ─────────────────────────────────────────────────────────────
# reCAPTCHA v3 (login gate protection — optional)
# console.cloud.google.com → reCAPTCHA Enterprise
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key


# ─────────────────────────────────────────────────────────────
# Mapbox (interactive order tracking map — optional)
# mapbox.com → Account → Access tokens → Create token (public scope only)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token


# ─────────────────────────────────────────────────────────────
# Vercel Cron Secret (authenticates /api/cron/* endpoints)
# Generate with: openssl rand -hex 32
# Set same value in Vercel dashboard → Environment Variables
# ─────────────────────────────────────────────────────────────
CRON_SECRET=your-random-cron-secret
