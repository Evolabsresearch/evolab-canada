# ============================================================
# EVO Labs Research CANADA — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
#
# 🇨🇦 = MUST be a NEW/separate value for Canada (do NOT reuse US)
# 🔁 = CAN reuse the same value from your US site
# ============================================================


# ─────────────────────────────────────────────────────────────
# 🇨🇦 Supabase — CREATE A NEW PROJECT for Canada
# Dashboard → New Project → Settings → API
# Keeps Canadian customer data separate (PIPEDA compliance)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-canada-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-canada-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-canada-service-role-key


# ─────────────────────────────────────────────────────────────
# 🇨🇦 NextAuth.js — NEW secret + Canadian domain
# NEXTAUTH_SECRET: run `openssl rand -base64 32` to generate a NEW one
# NEXTAUTH_URL: your Canadian domain (no trailing slash)
# ─────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-NEW-random-32-char-secret
NEXTAUTH_URL=https://evolabsresearch.ca


# ─────────────────────────────────────────────────────────────
# 🇨🇦 Email — SMTP (Magic Link auth + transactional mail)
# You need a verified sending domain for evolabsresearch.ca
# Resend: resend.com → Domains → Add evolabsresearch.ca
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-canada-resend-api-key
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=re_your-canada-resend-api-key
EMAIL_FROM=EVO Labs Research Canada <noreply@evolabsresearch.ca>


# ─────────────────────────────────────────────────────────────
# 🔁 Twilio — Can reuse same account, or create separate
# console.twilio.com → Verify → Services
# Consider a Canadian phone number for SMS sender ID
# ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ─────────────────────────────────────────────────────────────
# 🇨🇦 Admin Panel — Use NEW credentials for Canada
# ─────────────────────────────────────────────────────────────
ADMIN_SECRET=your-canada-admin-api-secret-token
NEXT_PUBLIC_ADMIN_EMAIL=your-canada-admin@email.com
NEXT_PUBLIC_ADMIN_PW=your-canada-admin-password


# ─────────────────────────────────────────────────────────────
# 🇨🇦 Hummingbird Payments — NEW account for CAD processing
# hummingbird.paywithwallet.net → Create new merchant for CAD
# ─────────────────────────────────────────────────────────────
HUMMINGBIRD_SERVER_URL=https://hummingbird.paywithwallet.net
HUMMINGBIRD_PUBLIC_KEY=your-canada-hummingbird-public-key
HUMMINGBIRD_SECRET_KEY=your-canada-hummingbird-secret-key


# ─────────────────────────────────────────────────────────────
# 🇨🇦 Stripe — NEW account for CAD processing
# dashboard.stripe.com → Create new account for Canada
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_ENABLED=false
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-canada-publishable-key
STRIPE_SECRET_KEY=sk_live_your-canada-secret-key


# ─────────────────────────────────────────────────────────────
# 🇨🇦 Link.money / EFT (Canadian bank payments — optional)
# ─────────────────────────────────────────────────────────────
LINKMONEY_CLIENT_ID=your-canada-linkmoney-client-id
LINKMONEY_CLIENT_SECRET=your-canada-linkmoney-client-secret
LINKMONEY_API_BASE_URL=https://api.link.money
LINKMONEY_REDIRECT_URL=https://evolabsresearch.ca/checkout


# ─────────────────────────────────────────────────────────────
# 🇨🇦 Shipping — Ship-from address (Toronto fulfillment)
# Update with your ACTUAL Canadian warehouse/business address
# ─────────────────────────────────────────────────────────────
SHIPPO_API_KEY=your-shippo-api-key
SHIPPO_TEST_MODE=true

SHIP_FROM_NAME=EVO Labs Research Canada
SHIP_FROM_COMPANY=EVO Labs Research Canada
SHIP_FROM_STREET=100 King Street West, Suite 5600
SHIP_FROM_CITY=Toronto
SHIP_FROM_STATE=ON
SHIP_FROM_ZIP=M5X 1C9
SHIP_FROM_COUNTRY=CA
SHIP_FROM_PHONE=6475550199


# ─────────────────────────────────────────────────────────────
# 🔁 AfterShip — Can reuse same account
# app.aftership.com → Settings → API Keys
# ─────────────────────────────────────────────────────────────
AFTERSHIP_API_KEY=your-aftership-api-key


# ─────────────────────────────────────────────────────────────
# 🇨🇦 Omnisend — NEW workspace recommended (CASL compliance)
# Separate workspace keeps CA/US subscriber lists clean
# app.omnisend.com → Create new store → API Keys
# ─────────────────────────────────────────────────────────────
OMNISEND_API_KEY=your-canada-omnisend-api-key
NEXT_PUBLIC_OMNISEND_BRAND_ID=your-canada-omnisend-brand-id


# ─────────────────────────────────────────────────────────────
# 🔁 WooCommerce REST API — Can reuse if same product catalog
# If you want separate Canadian pricing, set up a new WC store
# ─────────────────────────────────────────────────────────────
WC_STORE_URL=https://evolabsresearch.com
WC_CONSUMER_KEY=ck_your_consumer_key
WC_CONSUMER_SECRET=cs_your_consumer_secret
WC_WEBHOOK_SECRET=your-woocommerce-webhook-secret


# ─────────────────────────────────────────────────────────────
# 🔁 Anthropic Claude — Can reuse same API key
# console.anthropic.com → API Keys
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key


# ─────────────────────────────────────────────────────────────
# 🇨🇦 Google Analytics 4 — NEW property for Canada
# analytics.google.com → Admin → Create Property → evolabsresearch.ca
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX


# ─────────────────────────────────────────────────────────────
# 🇨🇦 reCAPTCHA v3 — Register new site for evolabsresearch.ca
# console.cloud.google.com → reCAPTCHA Enterprise → Add domain
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-canada-recaptcha-site-key


# ─────────────────────────────────────────────────────────────
# 🔁 Mapbox — Can reuse same token (add evolabsresearch.ca to allowed URLs)
# mapbox.com → Account → Access tokens
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token


# ─────────────────────────────────────────────────────────────
# 🇨🇦 Vercel Cron Secret — Generate NEW one
# openssl rand -hex 32
# ─────────────────────────────────────────────────────────────
CRON_SECRET=your-canada-cron-secret
